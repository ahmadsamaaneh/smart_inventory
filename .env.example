APP_ENV=development
PORT=8080

# ---- Database ----
# Driver: "postgres" (default) or "sqlite"
DB_DRIVER=postgres

# Option A: provide a full DSN (overrides PG_* below)
# DB_DSN=host=localhost port=5432 user=postgres password=postgres dbname=inventory sslmode=disable TimeZone=UTC

# Option B: composable Postgres settings
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DB=inventory
PG_SSLMODE=disable
PG_TIMEZONE=UTC

# Connection pool / startup retry
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFE_MINUTES=30
DB_CONNECT_RETRIES=10
DB_CONNECT_RETRY_WAIT_SECONDS=2

# For local dev without Docker you can fall back to SQLite:
# DB_DRIVER=sqlite
# DB_DSN=data.db

# ---- Auth ----
JWT_SECRET=change-me-to-a-long-random-string
JWT_TTL_HOURS=24

# Bootstrap admin user created on first run if it does not exist
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin123!
